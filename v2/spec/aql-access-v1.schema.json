{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ifuri.com/schemas/aql-access-v1.schema.json",
  "title": "AQL standing access contract v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "contract_id", "environment", "grants"],
  "properties": {
    "schema_version": {"const": "aql.access.v1"},
    "contract_id": {"type": "string", "minLength": 1},
    "environment": {"type": "string", "minLength": 1},
    "valid_until": {"type": ["string", "null"], "format": "date-time"},
    "grants": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "grant_id",
          "actor",
          "actions",
          "providers",
          "capabilities",
          "targets"
        ],
        "properties": {
          "grant_id": {"type": "string", "minLength": 1},
          "actor": {"type": "string", "minLength": 1},
          "actions": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "enum": [
                "ALLOW_DISCOVER",
                "ALLOW_ACQUIRE",
                "ALLOW_USE",
                "ALLOW_DELEGATE",
                "ALLOW_ROTATE",
                "ALLOW_REVOKE",
                "ALLOW_MUTATE",
                "ALLOW_SPEND",
                "ALLOW_ACCEPT_TERMS"
              ]
            }
          },
          "providers": {"$ref": "#/$defs/patterns"},
          "capabilities": {"$ref": "#/$defs/patterns"},
          "targets": {"$ref": "#/$defs/patterns"},
          "max_credential_ttl_seconds": {"type": "integer", "minimum": 1},
          "max_cost": {"type": "number", "minimum": 0}
        }
      }
    }
  },
  "$defs": {
    "patterns": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    }
  }
}
