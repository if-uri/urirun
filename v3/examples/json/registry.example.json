{
  "device": {
    "led": {
      "set": {
        "kind": "function",
        "adapter": "local-function",
        "config": {},
        "policy": { "allowArgs": true, "allowPayload": true, "cacheable": true }
      }
    }
  },
  "log": {
    "info": {
      "user-created": {
        "kind": "function",
        "adapter": "local-function",
        "config": {},
        "policy": { "allowArgs": true, "allowPayload": true, "cacheable": true }
      }
    }
  },
  "service": {
    "user": {
      "create": {
        "kind": "http",
        "adapter": "fetch",
        "config": {
          "method": "POST",
          "url": "http://user-service.local/api/users"
        }
      }
    }
  },
  "cli": {
    "git": {
      "status": {
        "kind": "cli",
        "adapter": "spawn",
        "config": {
          "command": ["git", "status"]
        }
      }
    }
  },
  "shell": {
    "system": {
      "restart": {
        "kind": "shell",
        "adapter": "shell-template",
        "config": {
          "template": "systemctl restart {0}"
        }
      }
    }
  },
  "mqtt": {
    "publish": {
      "home": {
        "kind": "mqtt",
        "adapter": "mqtt-publish",
        "config": {
          "topicPrefix": "home"
        }
      }
    }
  },
  "artifact": {
    "build": {
      "frontend": {
        "kind": "process",
        "adapter": "spawn",
        "config": {
          "command": ["npm", "run", "build"]
        }
      }
    }
  }
}
