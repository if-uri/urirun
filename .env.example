# =============================================================================
# if-uri / urirun — centralna konfiguracja modeli i autonomii
# =============================================================================
# Ten plik jest ŹRÓDŁEM PRAWDY dla wszystkich modeli LLM w ekosystemie if-uri.
# Ładowany automatycznie przez: dashboard /work, agent://, koru, loop, twin-human.
# Zmienne już ustawione w shellu NIE są nadpisywane.
#
# Ścieżka kanoniczna: <project>/urirun/.env
# Alias: URIRUN_ENV=/home/tom/github/if-uri/urirun/.env (dla skryptów examples/)
# =============================================================================

URIRUN_DOTENV=1
URIRUN_ENV=/home/tom/github/if-uri/urirun/.env
URIRUN_KORU_PROJECT=/home/tom/github/if-uri

# =============================================================================
# API keys (odkomentuj / uzupełnij providera, którego używasz)
# =============================================================================
OPENROUTER_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GROQ_API_KEY=
# OLLAMA_HOST=http://localhost:11434

# =============================================================================
# Role modeli (Triple LLM + Developer)
# Jedna kanoniczna nazwa na rolę — bez aliasów URIRUN_LLM_MODEL_* (niepotrzebna
# kompatybilność wsteczna, kod czyta tylko LLM_MODEL_* teraz).
# =============================================================================

# --- EXECUTOR (actor) — szybkie decyzje w pętli observe-act / KVM / GUI ---
LLM_MODEL_EXECUTOR=openrouter/google/gemini-3.5-flash

# --- DEVELOPER — tickety kodowe, agent://, aider (główna rola „kto pisze kod”) ---
LLM_MODEL_DEVELOPER=openrouter/deepseek/deepseek-v4-pro
URIRUN_AGENT_MODEL=openrouter/deepseek/deepseek-v4-pro

# --- VALIDATOR — drugi model: wiedza, bezpieczeństwo, PASS/FAIL przed akcją ---
LLM_MODEL_VALIDATOR=openrouter/deepseek/deepseek-v4-pro

# --- TEACHER — analiza screenshotów / wizja (lepszy od Gemini w GUI grounding) ---
LLM_MODEL_TEACHER=openrouter/qwen/qwen3.7-plus

# --- EXECUTOR TWIN — drugi blizniak executora (A/B: szybkość + jakość) ---
LLM_MODEL_EXECUTOR_TWIN=openrouter/minimax/minimax-m3

# --- LEGACY / fallback ogólny (chat, planner, litellm) ---
# URIRUN_LLM_MODEL zostaje: czyta go ~20 innych modułów w ekosystemie (examples/,
# testing/, urirun-flow, dashboard_api.py) jako ogólny fallback — to nie jest
# rola-specyficzny alias, tylko osobny, szeroko używany klucz.
LLM_MODEL=openrouter/qwen/qwen3.7-plus
URIRUN_LLM_MODEL=openrouter/google/gemini-3.5-flash

# --- PLANNER — planowanie ticketów / nxdo / inquiry (koru planning LLM) ---
LLM_MODEL_PLANNER=openrouter/qwen/qwen3-coder-next
KORU_PLANNING_LLM_MODEL=openrouter/qwen/qwen3-coder-next
KORU_NXDO_MODEL=openrouter/google/gemini-2.5-flash

# --- CHAT — orchestrator dashboardu / NL→ticket (gdy inny niż ogólny) ---
LLM_MODEL_CHAT=openrouter/google/gemini-3.5-flash

# --- VISION / OCR / scanner ---
LLM_MODEL_VISION=openrouter/qwen/qwen3.7-plus
URIRUN_SCANNER_LLM_MODEL=openrouter/qwen/qwen3.7-plus
URIRUN_SCANNER_LLM_VISION_MODEL=openrouter/qwen/qwen3.7-plus
URIRUN_SCANNER_LLM_API_KEY_REF=secret://dotenv/urirun/.env

#OPENROUTER_API_KEY

# --- Ollama (lokalny fallback agent://) ---
URIRUN_OLLAMA_MODEL=llama3

# =============================================================================
# Agent headless (agent://) — wykonanie ticketów z panelu /work
# =============================================================================
# URIRUN_AGENT_DEFAULT: aider|claude|codex|opencode|gemini|ollama|auto
#   aider + URIRUN_AGENT_MODEL = pełna kontrola przez OpenRouter (zalecane)
URIRUN_AGENT_DEFAULT=aider
URIRUN_AGENT_AUTONOMOUS=1
URIRUN_AGENT_MAX_CONCURRENT=1

# =============================================================================
# Koru / tillm — autonomiczna pętla ticketów
# =============================================================================
URIRUN_KORU_IDE=aider
KORU_TILLM_CLIENT=aider
KORU_TILLM_MODEL=openrouter/deepseek/deepseek-v4-pro
KORU_TILLM_EXECUTE_PROFILE=
KORU_TILLM_TIMEOUT_SECONDS=600
KORU_TILLM_DRY_RUN=0
# KORU_TILLM_PATH=~/github/semcod/tillm

KORU_PLANNING_LLM=1
KORU_PLANNING_LLM_TIMEOUT=30
KORU_LLM_REFLECT=1

KORU_AUTOPILOT_IDE=auto
# KORU_AUTOPILOT_INSTANCE=main
KORU_AUTOPILOT_BACKEND=tillm_shell

# Bramki pracy (work://claim-next) i fallback wykonawcy
KORU_WORK_GATE=hard
KORU_EXECUTOR_FALLBACK=soft
# KORU_WORKER_ID=host-dashboard

# NXDO discovery (automatyczne uzupełnianie backlogu)
KORU_NXDO_COOLDOWN_SECONDS=3600
# KORU_NXDO_EXTRA_CONTEXT=

# =============================================================================
# pfix — Self-healing Python (auto-fix via LLM)
# =============================================================================
PFIX_AUTO_APPLY=true
PFIX_AUTO_INSTALL_DEPS=true
PFIX_AUTO_RESTART=false
PFIX_MAX_RETRIES=3
PFIX_DRY_RUN=false
PFIX_ENABLED=true
PFIX_GIT_COMMIT=false
PFIX_GIT_PREFIX=pfix:
PFIX_CREATE_BACKUPS=false

# =============================================================================
# Dashboard / work panel URLs
# =============================================================================
URIRUN_DASHBOARD_BASE=http://127.0.0.1:8797
URIRUN_WORK_DASHBOARD_BASE=http://127.0.0.1:8797
URIRUN_CHAT_BASE=http://127.0.0.1:8194
URIRUN_CHAT_HOST=127.0.0.1
URIRUN_CHAT_PORT=8194
URIRUN_LAN_QR_BASE=http://127.0.0.1:8195

# =============================================================================
# Węzły / KVM / twin-human (real-world automation)
# =============================================================================
URIRUN_HOST_URL=http://localhost:8765
URIRUN_LENOVO_URL=http://192.168.188.201:8765
URIRUN_NVIDIA_URL=http://localhost:8765

# Signal / KVM E2E (twin-human, deliver_signal, loop)
URIRUN_SIGNAL_KVM_NODE=lenovo
URIRUN_KVM_URI_HOST=host
SIGNAL_DEFAULT_RECIPIENT=Mateusz
SIGNAL_APP_ID=org.signal.Signal
URIRUN_TWIN_HUMAN_ACTOR=twin-human:tom
SIGNAL_E2E_MESSAGE_TEMPLATE=E2E {ticket_id} ok — if-uri autonomy
SIGNAL_GUI_VISION_MODEL=openrouter/qwen/qwen3.7-plus

# =============================================================================
# Connector discovery / artefakty
# =============================================================================
URIRUN_CONNECTOR_ROOTS=~/github
URIRUN_ERROR_LOG=~/.urirun/errors.jsonl
URIRUN_ARTIFACT_DIR=~/.urirun/artifacts
URIRUN_WORK_RUNS_DIR=~/.urirun/host-dashboard/work-runs

# Topologia URI runtime dla LLM (compose/uri-runtime + generate-environment-context.py)
URIRUN_URI_TOPOLOGY_FILE=compose/uri-runtime/generated/environment.context.yaml

# =============================================================================
# Notatki operacyjne
# =============================================================================
# Każde zadanie KVM/Signal powinno zaczynać się od prepare_and_validate
# (EXECUTOR + VALIDATOR + TEACHER).
# Tickety kodowe: URIRUN_AGENT_DEFAULT=aider + LLM_MODEL_DEVELOPER.
# Koru: URIRUN_KORU_IDE + KORU_TILLM_MODEL (ten sam model co developer, jeśli chcesz spójność).
# Po zmianie .env: zrestartuj dashboard 8797 i wznów koru (POST /api/work/koru).
